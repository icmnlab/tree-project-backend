# ===========================================================================
# ML Service（Python）環境變數範本 — 複製為 .env 並填入實際值
#   cp .env.example .env
# .env 已被 .gitignore 忽略；切勿 commit 真實金鑰。
#
# 注意：模型與加速器（深度模型、SAM、OpenVINO）是由啟動腳本的 preset 決定，
#       例如 `./start.ps1 -Preset da3`（預設）會設定 da3_metric_large + OpenVINO，
#       並覆寫對應環境變數。因此一般不需在 .env 指定模型，只放機密與基礎設定即可。
# ===========================================================================

# 與後端 ML_API_KEY 對應，用於驗證後端代理請求（必填）
ML_API_KEY=your_ml_api_key_here

# 服務埠
PORT=8100

# CORS 允許來源（多個用逗號分隔）
ML_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- 效能（依硬體調整；選用）---
ML_CPU_THREADS=6
OMP_NUM_THREADS=4
MKL_NUM_THREADS=4

# --- 速率限制（選用）---
# 每 IP 每小時請求數上限（記憶體計數，重啟歸零）
# ML_RATE_LIMIT=30

# --- 模型覆寫（選用；一般交由 start.ps1 -Preset 控制，留白即可）---
# 預設 preset(da3) 等同於以下組合（由 start.ps1 注入）：
#   ML_DEPTH_MODEL=da3_metric_large
#   ML_USE_OPENVINO=true
#   ML_DA3_OV_DIR=openvino_models\da3_metric_large
#   ML_DA3_OV_DEVICE=NPU              # 無 NPU 可改 GPU / CPU / AUTO
#   ML_ENABLE_SAM=false
#   ML_FORCE_SERVER_YOLO=true         # /auto-measure-dbh 用伺服器端 YOLOv8-seg 遮罩
#   ML_SERVER_YOLO_DEVICE=intel:gpu
#   ML_SERVER_YOLO_IMGSZ=832
# 直接以 uvicorn 啟動（不經 start 腳本）時，請自行設定上述變數。
# ML_DEPTH_MODEL=
# ML_SEG_MODEL=
# ML_ENABLE_SAM=false
# ML_USE_OPENVINO=true
# ML_OPENVINO_DIR=./openvino_models
# ML_OV_DEVICE=AUTO
# ML_DEBUG=false

# --- 訓練腳本用（trunk_detector_training/，非 runtime；選用）---
# 取得：Kaggle 帳號 Settings → API；Roboflow 帳號 Settings → API key
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_key
ROBOFLOW_API_KEY=your_roboflow_key
