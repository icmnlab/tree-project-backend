{
  "name": "tree-survey-backend",
  "version": "1.0.0",
  "description": "Backend for tree survey application",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "test": "node tests/intentClassification.test.js && node tests/sqlValidation.test.js",
    "test:intent": "node tests/intentClassification.test.js",
    "test:sql": "node tests/sqlValidation.test.js",
    "test:integration": "node tests/chatIntegration.test.js",
    "test:api": "node tests/apiIntegration.test.js",
    "test:regression": "node tests/regression.test.js",
    "test:regression:local": "node tests/regression.test.js --local",
    "test:regression:verbose": "node tests/regression.test.js --verbose",
    "test:all": "node tests/regression.test.js && node tests/apiIntegration.test.js && node tests/securityAudit.test.js"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.51.0",
    "@google/generative-ai": "^0.24.1",
    "@turf/turf": "^7.3.5",
    "axios": "^1.7.9",
    "bcryptjs": "^3.0.2",
    "chardet": "^2.1.1",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.5.0",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "form-data": "^4.0.5",
    "helmet": "^8.1.0",
    "iconv-lite": "^0.6.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "openai": "^4.96.0",
    "pdfkit": "^0.17.0",
    "pg": "^8.12.0",
    "pg-copy-streams": "^7.0.0",
    "pg-format": "^1.0.4",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
