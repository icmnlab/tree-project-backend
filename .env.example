# ===========================================================================
# 後端環境變數範本 — 複製為 .env 並填入實際值（.env 已被 .gitignore 忽略）
#   cp .env.example .env
# 切勿把真實金鑰寫進原始碼或 commit .env。
# ===========================================================================

# --- 資料庫（擇一：本機用 DB_* / 生產用 DATABASE_URL）---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tree_data
DB_USER=your_db_user
DB_PASSWORD=your_strong_password_here
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# 生產自簽憑證時設 false；正式憑證建議 true
DB_SSL_REJECT_UNAUTHORIZED=false
# 本機 / CI 連「無 SSL」的 Postgres 時設 false（或 PGSSLMODE=disable）。
# 未設且有 DATABASE_URL → 預設啟用 SSL（雲端託管 DB 行為不變）。見 config/pgSsl.js。
# DB_SSL=false

# --- 認證（JWT_SECRET 請用 openssl rand -hex 64 產生）---
JWT_SECRET=your_strong_jwt_secret_min_32_chars
JWT_EXPIRES_IN=24h

# --- 伺服器 ---
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000
# CORS 允許來源（多個用逗號分隔）
CORS_ALLOWED_ORIGINS=http://localhost:5173
# 舊版單一來源變數（選用；未設 CORS_ALLOWED_ORIGINS 時的後備）
# CORS_ORIGIN=http://localhost:5173

# --- 部署 / 管理 ---
# /webhook/status 部署診斷用（admin UI 已改用 JWT，不需此 token）
ADMIN_API_TOKEN=your_admin_token_here
# GitHub webhook HMAC secret（自動部署用）
DEPLOY_WEBHOOK_SECRET=your_github_webhook_secret

# --- ML Service（樹幹偵測 / 深度估計代理）---
ML_SERVICE_URL=http://127.0.0.1:8100
# 對外公開（Tailscale / ngrok）位址，前端透過後端取得
ML_SERVICE_PUBLIC_URL=https://your-public-ml-host
ML_API_KEY=your_ml_api_key_here

# --- Cloudinary（樹木照片儲存；三項缺一不可）---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# --- AI 供應商（選用；未設定則對應功能停用）---
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
Claude_API_KEY=your_claude_api_key_here
SiliconFlow_API_KEY=your_siliconflow_api_key_here
Alt1_SiliconFlow_API_KEY=your_alt1_key_here
Alt2_SiliconFlow_API_KEY=your_alt2_key_here
Alt3_SiliconFlow_API_KEY=your_alt3_key_here
# PlantNet 樹種辨識（註冊：https://my.plantnet.org/signup）
PLANTNET_API_KEY=your_plantnet_api_key_here

# --- AI Agent / 搜尋（選用）---
GOOGLE_CSE_API_KEY=your_google_cse_key
GOOGLE_CSE_CX=your_search_engine_id
# AGENT_DEFAULT_MODEL=gpt-5.4-mini
# AGENT_SQL_MODEL=gpt-5.4-mini
# Agent 網頁抓取調校（皆選用，留白用程式預設）
# AGENT_FETCH_TIMEOUT_MS=8000
# AGENT_FETCH_MAX_BYTES=2000000
# AGENT_FETCH_CACHE_TTL_MS=300000
# 允許 agent 抓取的額外主機後綴（逗號分隔，預設只允許白名單）
# AGENT_EXTRA_HOST_SUFFIXES=.example.edu.tw

# --- LLM 調校（選用，留白用程式預設）---
# LLM 健康檢查快取毫秒
# LLM_HEALTH_CACHE_MS=60000
# OpenAI 主模型不可用時的後備模型
# LLM_OPENAI_FALLBACK_MODEL=gpt-4o-mini
# 樹種目錄查詢用的 OpenAI 模型旗標
# OPENAI_CATALOG_GPT5=false

# --- 功能開關（皆為選用，留白用程式預設）---
# HANDBOOK_ENFORCE_DBH=true
# SKIP_CSV_IMPORT=false          # 正式部署建議 1，避免匯入港務測試樹
# DISABLE_IP_GUARD=false
# 碳計算沿用舊版 TIPC 係數（選用）
# CARBON_CALC_LEGACY_TIPC=false
# 地圖偵錯記錄（選用）
# DEBUG_MAP=false

# --- 整合測試 / CI（請勿填生產密碼）---
TEST_BASE_URL=http://127.0.0.1:3000/api
# 部分測試改用 TEST_API_BASE（選用，未設則回退 TEST_BASE_URL）
# TEST_API_BASE=http://127.0.0.1:3000/api
TEST_ADMIN_USER=admin
TEST_ADMIN_PASS=your_test_password
# 調查管理員測試帳號（選用；對應 seed 的 test 帳號）
# TEST_SURVEY_USER=test
# TEST_SURVEY_PASS=your_test_password
# 指定既有 pending 量測 ID 給特定契約測試（選用）
# TEST_PENDING_ID=
# CI 跑 tests/runner.js 時設 true，讓 localhost 大量請求不被限流／IP 黑名單擋。
# DISABLE_RATE_LIMIT=true
# 直連 PG 做 read-only 斷言（不設則需 DB 的測試自動 skip）；本機通常等於 DATABASE_URL。
# TEST_DB_URL=postgres://user:pass@localhost:5432/dbname
